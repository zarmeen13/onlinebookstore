---
- name: Deploy onlinebookstore
  hosts: servers
  become: yes

  vars:
    tomcat_webapps: /var/lib/tomcat10/webapps
    backup_dir: /var/lib/tomcat10/webapps/backup
    war_name: onlinebookstore.war

  tasks:

    - name: Create backup directory
      file:
        path: "{{ backup_dir }}"
        state: directory
        mode: '0755'

    - name: Check if old WAR exists
      stat:
        path: "{{ tomcat_webapps }}/{{ war_name }}"
      register: old_war

    - name: Backup existing WAR
      copy:
        src: "{{ tomcat_webapps }}/{{ war_name }}"
        dest: "{{ backup_dir }}/{{ war_name }}"
        remote_src: yes
      when: old_war.stat.exists

    - name: Remove old exploded application
      file:
        path: "{{ tomcat_webapps }}/onlinebookstore"
        state: absent

    - name: Remove old WAR
      file:
        path: "{{ tomcat_webapps }}/{{ war_name }}"
        state: absent

    # Copy the latest WAR generated by the CURRENT Jenkins job
    - name: Copy new WAR from Jenkins workspace
      copy:
        src: /var/lib/jenkins/workspace/onlinebookstore-ansible/target/onlinebookstore.war
        dest: "{{ tomcat_webapps }}/{{ war_name }}"
        owner: tomcat
        group: tomcat
        mode: '0644'

    - name: Restart Tomcat
      service:
        name: tomcat10
        state: restarted

    - name: Wait until Tomcat application is available
      uri:
        url: http://localhost:8081/onlinebookstore/
        status_code: 200
      register: website
      retries: 20
      delay: 3
      until: website.status == 200

    - name: Install Nginx
      apt:
        name: nginx
        state: present
        update_cache: yes

    - name: Configure Nginx reverse proxy
      copy:
        dest: /etc/nginx/sites-available/default
        content: |
          server {
              listen 80;
              server_name _;

              location / {
                  proxy_pass http://localhost:8081/onlinebookstore/;
                  proxy_set_header Host $host;
                  proxy_set_header X-Real-IP $remote_addr;
                  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
                  proxy_set_header X-Forwarded-Proto $scheme;
              }
          }

    - name: Test nginx configuration
      command: nginx -t

    - name: Restart nginx
      service:
        name: nginx
        state: restarted
        enabled: yes

    - name: Wait until Nginx is serving the application
      uri:
        url: http://localhost/
        status_code: 200
      register: nginx_check
      retries: 20
      delay: 3
      until: nginx_check.status == 200

    - name: Wait until application is available
      uri:
        url: http://localhost:8081/onlinebookstore/
        status_code: 200
      register: website
      retries: 20
      delay: 3
      until: website.status == 200
