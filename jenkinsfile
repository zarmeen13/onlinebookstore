pipeline {
    agent any

    environment {
        BUILD_DIR = "target"
    }

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/zarmeen13/onlinebookstore.git'
            }
        }

        stage('Build with Maven') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Deploy to Tomcat') {
            steps {
                sh 'sudo cp target/*.war /var/lib/tomcat10/webapps/onlinebookstore.war'
                sh 'sudo systemctl restart tomcat10'
            }
        }
    }

    post {
        success {
            echo "Deployed successfully! Access at: http://44.200.108.88:8081/onlinebookstore"
        }
        failure {
            echo "Build or Deployment failed!"
        }
    }
}
