pipeline {

    agent any

    tools {
        maven 'Maven'
    }

    stages {

        stage('Clone Repository') {

            steps {

                git branch: 'main',
                url: 'https://github.com/zarmeen13/onlinebookstore.git'

            }

        }

        stage('Build Application') {

            steps {

                sh 'mvn clean package'

            }

        }

        stage('Backup Existing WAR') {

            steps {

                sh '''
                if [ -f /var/lib/tomcat10/webapps/onlinebookstore.war ]
                then
                    sudo cp /var/lib/tomcat10/webapps/onlinebookstore.war \
                    /var/lib/tomcat10/webapps/backup/onlinebookstore-$(date +%F-%H-%M-%S).war
                fi
                '''

            }

        }

        stage('Deploy to Tomcat') {

            steps {

                sh '''
                sudo cp target/onlinebookstore.war \
                /var/lib/tomcat10/webapps/
                '''

            }

        }

        stage('Restart Tomcat') {

            steps {

                sh '''
                sudo systemctl restart tomcat10
                '''
            }

        }

    }

    post {

        success {

            echo 'Deployment Successful'

        }

        failure {

            echo 'Deployment Failed'

        }

    }

}
